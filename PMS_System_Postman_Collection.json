{
  "info": {
    "_postman_id": "pms-system-collection-001",
    "name": "PMS System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for PMS System Django project."
  },
  "item": [
    {
      "name": "User Authentication & Dashboard",
      "item": [
        { "name": "Home", "request": { "method": "GET", "url": "{{base_url}}/" } },
        { "name": "Login (AJAX)", "request": { "method": "POST", "url": "{{base_url}}/ajax_login/", "body": { "mode": "formdata", "formdata": [ { "key": "username", "value": "admin@example.com", "type": "text" }, { "key": "password", "value": "adminpass", "type": "text" } ] } } },
        { "name": "Admin Dashboard", "request": { "method": "GET", "url": "{{base_url}}/admin_dashboard/" } },
        { "name": "Teamlead Dashboard", "request": { "method": "GET", "url": "{{base_url}}/teamlead_dashboard/" } },
        { "name": "Employee Dashboard", "request": { "method": "GET", "url": "{{base_url}}/employee_dashboard/" } },
        { "name": "Logout", "request": { "method": "GET", "url": "{{base_url}}/logout/" } }
      ]
    },
    {
      "name": "User Management",
      "item": [
        { "name": "Register", "request": { "method": "POST", "url": "{{base_url}}/register/", "body": { "mode": "formdata", "formdata": [ { "key": "username", "value": "newuser", "type": "text" }, { "key": "email", "value": "newuser@example.com", "type": "text" }, { "key": "role", "value": "EMPLOYEE", "type": "text" }, { "key": "password1", "value": "password123", "type": "text" }, { "key": "password2", "value": "password123", "type": "text" } ] } } },
        { "name": "Create User", "request": { "method": "POST", "url": "{{base_url}}/create_user/", "body": { "mode": "formdata", "formdata": [ { "key": "username", "value": "employee1", "type": "text" }, { "key": "email", "value": "employee1@example.com", "type": "text" }, { "key": "role", "value": "EMPLOYEE", "type": "text" }, { "key": "password1", "value": "password123", "type": "text" }, { "key": "password2", "value": "password123", "type": "text" } ] } } },
        { "name": "Delete User", "request": { "method": "POST", "url": "{{base_url}}/delete_user/{{user_id}}/" } },
        { "name": "Edit User", "request": { "method": "POST", "url": "{{base_url}}/edit-user/{{user_id}}/", "body": { "mode": "formdata", "formdata": [ { "key": "username", "value": "employee1", "type": "text" }, { "key": "email", "value": "employee1@example.com", "type": "text" }, { "key": "role", "value": "EMPLOYEE", "type": "text" } ] } } },
        { "name": "View User Details", "request": { "method": "GET", "url": "{{base_url}}/view_user_details/{{user_id}}/" } },
        { "name": "Admin View Users", "request": { "method": "GET", "url": "{{base_url}}/admin-view-users/" } },
        { "name": "Teamlead View Users", "request": { "method": "GET", "url": "{{base_url}}/teamlead-view-users/" } }
      ]
    },
    {
      "name": "Project Management",
      "item": [
        { "name": "Create Project", "request": { "method": "POST", "url": "{{base_url}}/create_project/", "body": { "mode": "formdata", "formdata": [ { "key": "name", "value": "Project Alpha", "type": "text" }, { "key": "description", "value": "A new project.", "type": "text" }, { "key": "assigned_to", "value": "[1,2]", "type": "text" }, { "key": "start_date", "value": "2024-01-01", "type": "text" }, { "key": "end_date", "value": "2024-12-31", "type": "text" }, { "key": "status", "value": "PENDING", "type": "text" } ] } } },
        { "name": "View Projects", "request": { "method": "GET", "url": "{{base_url}}/view_projects/" } },
        { "name": "Edit Project", "request": { "method": "POST", "url": "{{base_url}}/edit_projects/{{project_id}}/", "body": { "mode": "formdata", "formdata": [ { "key": "name", "value": "Project Alpha Updated", "type": "text" }, { "key": "description", "value": "Updated description.", "type": "text" }, { "key": "assigned_to", "value": "[1,2]", "type": "text" }, { "key": "start_date", "value": "2024-01-01", "type": "text" }, { "key": "end_date", "value": "2024-12-31", "type": "text" }, { "key": "status", "value": "ONGOING", "type": "text" } ] } } },
        { "name": "Delete Project", "request": { "method": "POST", "url": "{{base_url}}/delete_project/{{id}}/" } },
        { "name": "View Project Detail", "request": { "method": "GET", "url": "{{base_url}}/view_project_detail/{{project_id}}/" } },
        { "name": "Add Project Resource", "request": { "method": "POST", "url": "{{base_url}}/project/{{project_id}}/add-resource/", "body": { "mode": "formdata", "formdata": [ { "key": "name", "value": "Resource 1", "type": "text" }, { "key": "file", "value": "", "type": "file" } ] } } },
        { "name": "Employee Projects", "request": { "method": "GET", "url": "{{base_url}}/employee_projects/" } }
      ]
    },
    {
      "name": "Task Management",
      "item": [
        { "name": "Assign Task", "request": { "method": "POST", "url": "{{base_url}}/assign_task/", "body": { "mode": "formdata", "formdata": [ { "key": "name", "value": "Task 1", "type": "text" }, { "key": "description", "value": "Task details.", "type": "text" }, { "key": "project", "value": "1", "type": "text" }, { "key": "assigned_to", "value": "[2]", "type": "text" }, { "key": "assigned_by", "value": "1", "type": "text" }, { "key": "status", "value": "PENDING", "type": "text" }, { "key": "start_date", "value": "2024-01-01", "type": "text" }, { "key": "end_date", "value": "2024-01-10", "type": "text" }, { "key": "deadline", "value": "2024-01-10T17:00", "type": "text" }, { "key": "observers", "value": "[3]", "type": "text" }, { "key": "summary", "value": "", "type": "text" }, { "key": "estimated_time", "value": "3600", "type": "text" } ] } } },
        { "name": "Employee Tasks", "request": { "method": "GET", "url": "{{base_url}}/employee_tasks/" } },
        { "name": "Update Task Status", "request": { "method": "POST", "url": "{{base_url}}/update_task/{{task_id}}/", "body": { "mode": "formdata", "formdata": [ { "key": "status", "value": "COMPLETED", "type": "text" } ] } } },
        { "name": "Start Task", "request": { "method": "POST", "url": "{{base_url}}/start_task/{{task_id}}/" } },
        { "name": "Pause Task", "request": { "method": "POST", "url": "{{base_url}}/task/{{task_id}}/pause/" } },
        { "name": "Resume Task", "request": { "method": "POST", "url": "{{base_url}}/task/{{task_id}}/resume/" } },
        { "name": "Complete Task", "request": { "method": "POST", "url": "{{base_url}}/task/{{task_id}}/complete/" } },
        { "name": "Edit Task", "request": { "method": "POST", "url": "{{base_url}}/task/{{task_id}}/edit/", "body": { "mode": "formdata", "formdata": [ { "key": "name", "value": "Task 1 Updated", "type": "text" }, { "key": "description", "value": "Updated details.", "type": "text" }, { "key": "status", "value": "ONGOING", "type": "text" } ] } } },
        { "name": "Delete Task", "request": { "method": "POST", "url": "{{base_url}}/task/{{task_id}}/delete/" } },
        { "name": "Add Task Summary", "request": { "method": "POST", "url": "{{base_url}}/task/{{task_id}}/add-summary/", "body": { "mode": "formdata", "formdata": [ { "key": "summary", "value": "Completed successfully.", "type": "text" } ] } } },
        { "name": "Task Dashboard (My Tasks)", "request": { "method": "GET", "url": "{{base_url}}/my-tasks/" } },
        { "name": "AI Generate Description", "request": { "method": "POST", "url": "{{base_url}}/ai/generate-description/", "body": { "mode": "raw", "raw": "{\n  \"task_name\": \"Task 1\",\n  \"project_name\": \"Project Alpha\",\n  \"current_description\": \"\"\n}" } } }
      ]
    },
    {
      "name": "Departments & Designations",
      "item": [
        { "name": "Departments List", "request": { "method": "GET", "url": "{{base_url}}/departments/" } },
        { "name": "Department Detail", "request": { "method": "GET", "url": "{{base_url}}/department_detail/{{dept_id}}/" } },
        { "name": "Create Department", "request": { "method": "POST", "url": "{{base_url}}/department/create/", "body": { "mode": "formdata", "formdata": [ { "key": "name", "value": "HR", "type": "text" } ] } } },
        { "name": "Delete Department", "request": { "method": "POST", "url": "{{base_url}}/department/delete/{{dept_id}}/" } },
        { "name": "Designations List", "request": { "method": "GET", "url": "{{base_url}}/designations/" } },
        { "name": "Designation Detail", "request": { "method": "GET", "url": "{{base_url}}/designation_detail/{{desig_id}}/" } },
        { "name": "Create Designation", "request": { "method": "POST", "url": "{{base_url}}/designation/create/", "body": { "mode": "formdata", "formdata": [ { "key": "name", "value": "Manager", "type": "text" } ] } } },
        { "name": "Delete Designation", "request": { "method": "POST", "url": "{{base_url}}/designation/delete/{{desig_id}}/" } }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        { "name": "All Notifications", "request": { "method": "GET", "url": "{{base_url}}/notifications/all/" } },
        { "name": "Mark Notification as Read", "request": { "method": "POST", "url": "{{base_url}}/notifications/mark-read/{{notif_id}}/" } }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        { "name": "User Analytics", "request": { "method": "GET", "url": "{{base_url}}/user-analytics/" } }
      ]
    },
    {
      "name": "Password Reset",
      "item": [
        { "name": "Reset Password", "request": { "method": "POST", "url": "{{base_url}}/reset_password/" } },
        { "name": "Password Reset Done", "request": { "method": "GET", "url": "{{base_url}}/password_reset_done/" } },
        { "name": "Password Reset Confirm", "request": { "method": "POST", "url": "{{base_url}}/reset/{{uidb64}}/{{token}}/" } },
        { "name": "Password Reset Complete", "request": { "method": "GET", "url": "{{base_url}}/reset_password_complete/" } }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "user_id", "value": "1" },
    { "key": "project_id", "value": "1" },
    { "key": "task_id", "value": "1" },
    { "key": "dept_id", "value": "1" },
    { "key": "desig_id", "value": "1" },
    { "key": "notif_id", "value": "1" },
    { "key": "uidb64", "value": "sampleuid" },
    { "key": "token", "value": "sampletoken" },
    { "key": "id", "value": "1" }
  ]
}
